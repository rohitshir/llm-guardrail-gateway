{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SupportAnswer",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "answer",
    "citations",
    "confidence",
    "next_action"
  ],
  "properties": {
    "answer": {
      "type": "string",
      "minLength": 1
    },
    "citations": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Source identifiers or URLs used to support the answer."
    },
    "confidence": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "next_action": {
      "type": "string"
    }
  }
}